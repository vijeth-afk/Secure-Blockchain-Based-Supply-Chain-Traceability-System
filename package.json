{
  "scripts": {
    "start": "npm-run-all --parallel start:backend start:client",
    "start:backend": "cd backend && npm start",
    "start:client": "cd client && npm start",
    "dev": "npm-run-all --parallel dev:backend start:client",
    "dev:backend": "cd backend && npm run dev"
  },
  "dependencies": {
    "truffle": "^5.7.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5"
  }
}